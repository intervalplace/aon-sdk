{
  "name": "@intervalplace/aon-sdk",
  "version": "0.1.0",
  "description": "Executor and namespace SDK for the Authorization Object Network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "test:evm-spot": "node scripts/testEvmSpotObjects.mjs",
    "test:reserve": "node scripts/testReserveFlow.mjs",
    "test:csd-auth": "node scripts/testSignedCsdAuth.mjs",
    "test:executor": "node scripts/testExecutorAuto.mjs"
  },
  "dependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/intervalplace/aon-sdk.git"
  },
  "license": "MIT"
}
